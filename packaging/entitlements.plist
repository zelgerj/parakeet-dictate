<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- numba/llvmlite erzeugen zur Laufzeit ausführbaren Code (JIT).
         Unter Hardened Runtime (für Notarisierung nötig) braucht das diese Rechte. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- PyInstaller bündelt viele .dylib/.so; Library Validation deaktivieren,
         damit sie geladen werden dürfen. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Mikrofonzugriff unter Hardened Runtime (non-sandboxed): ZWINGEND nötig,
         sonst blockiert macOS das Mikrofon und die App erscheint nicht einmal in
         der Mikrofon-Liste der Systemeinstellungen. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
